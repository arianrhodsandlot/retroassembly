{
  "private": true,
  "repository": "arianrhodsandlot/retroassembly",
  "type": "module",
  "imports": {
    "#@/*": "./src/*"
  },
  "scripts": {
    "build": "vp build",
    "build:node": "node --run=build",
    "build:workerd": "node --run=build",
    "check-lockfile": "node scripts/check-lockfile.ts",
    "dev": "vp dev",
    "dev:node": "node --run=dev",
    "dev:test": "node --run=test -- --headed --ui",
    "dev:workerd": "node --run=dev",
    "lint": "vp check",
    "lint:fix": "vp check --fix",
    "prepare": "simple-git-hooks || exit 0",
    "serve": "node dist/server",
    "serve:node": "node --run=serve",
    "serve:workerd": "wrangler dev --port=8000",
    "setup": "node scripts/setup.ts",
    "start": "node --run=serve",
    "tag": "node scripts/tag.ts",
    "test": "playwright test -c tests/e2e --tsconfig=tests/e2e/tsconfig.playwright.json"
  },
  "dependencies": {
    "better-sqlite3": "12.8.0"
  },
  "devDependencies": {
    "@arianrhodsandlot/vite-plus-config": "1.0.2",
    "@cloudflare/vite-plugin": "1.30.0",
    "@hono/node-server": "1.19.11",
    "@hono/vite-dev-server": "0.25.1",
    "@hono/zod-validator": "0.7.6",
    "@iconify-json/logos": "1.2.10",
    "@iconify-json/mdi": "1.2.3",
    "@iconify-json/noto": "1.2.7",
    "@iconify-json/simple-icons": "1.2.74",
    "@iconify-json/svg-spinners": "1.2.4",
    "@iconify-json/twemoji": "1.2.5",
    "@iconify/tailwind4": "1.2.3",
    "@microsoft/clarity": "1.0.2",
    "@playwright/test": "1.58.2",
    "@radix-ui/themes": "3.3.0",
    "@react-router/dev": "7.13.1",
    "@react-router/node": "7.13.1",
    "@supabase/ssr": "0.9.0",
    "@supabase/supabase-js": "2.99.3",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "@tsconfig/remix": "2.0.7",
    "@types/canvas-confetti": "1.9.0",
    "@types/js-cookie": "3.0.6",
    "@types/luxon": "3.7.1",
    "@types/nanoid-dictionary": "4.2.3",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/spark-md5": "3.0.5",
    "@typescript/native-preview": "7.0.0-dev.20260321.1",
    "@zip.js/zip.js": "2.8.23",
    "atropos": "2.0.2",
    "browser-fs-access": "0.38.0",
    "canvas-confetti": "1.9.4",
    "ci-info": "4.4.0",
    "clsx": "2.1.1",
    "delegated-events": "1.1.2",
    "drizzle-kit": "1.0.0-beta.19-d95b7a4",
    "drizzle-orm": "1.0.0-beta.19-d95b7a4",
    "es-toolkit": "1.45.1",
    "esbuild": "0.27.4",
    "execa": "9.6.1",
    "fuse.js": "7.1.0",
    "gamepad.js": "3.0.1",
    "goodcodes-parser": "2.5.0",
    "hono": "4.12.8",
    "hono-react-router-adapter": "0.6.5",
    "i18next": "25.10.0",
    "is-docker": "4.0.0",
    "isbot": "5.1.36",
    "jiti": "2.6.1",
    "jotai": "2.18.1",
    "jotai-ssr": "0.2.0",
    "js-cookie": "3.0.5",
    "luxon": "3.7.2",
    "miniflare": "4.20260317.1",
    "motion": "12.38.0",
    "msleuth": "github:arianrhodsandlot/msleuth",
    "nanoid": "5.1.7",
    "nanoid-dictionary": "5.0.0",
    "next-themes": "0.4.6",
    "nostalgist": "0.21.0",
    "path-to-regexp": "8.3.0",
    "quick-lru": "7.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "15.0.0",
    "react-i18next": "16.5.8",
    "react-router": "7.13.1",
    "react-router-templates": "github:remix-run/react-router-templates",
    "simple-git-hooks": "2.13.1",
    "smooth-scroll-into-view-if-needed": "2.0.2",
    "spark-md5": "3.0.2",
    "spatial-navigation-ts": "1.0.8",
    "swr": "2.4.1",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "tailwindcss-motion": "1.1.1",
    "tailwindcss-safe-area": "1.3.0",
    "tempy": "3.2.0",
    "vite-plugin-devtools-json": "1.0.0",
    "vite-plus": "0.1.13",
    "wrangler": "4.76.0",
    "zod": "4.3.6"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm vp staged"
  },
  "prettier": {
    "htmlWhitespaceSensitivity": "ignore",
    "jsSingleQuote": true,
    "jsxSingleQuote": true,
    "printWidth": 120,
    "semi": false,
    "singleQuote": true
  },
  "engines": {
    "node": ">=25.8.1"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "react-router-templates",
      "sharp",
      "simple-git-hooks",
      "unrs-resolver",
      "workerd"
    ],
    "patchedDependencies": {
      "@microsoft/clarity": "patches/@microsoft__clarity.patch",
      "goodcodes-parser": "patches/goodcodes-parser.patch",
      "selector-set": "patches/selector-set.patch",
      "spatial-navigation-ts": "patches/spatial-navigation-ts.patch"
    }
  },
  "hintConfig": {
    "extends": [
      "development"
    ],
    "hints": {
      "apple-touch-icons": "off",
      "compat-api/html": [
        "default",
        {
          "ignore": [
            "meta[name=theme-color]"
          ]
        }
      ],
      "no-inline-styles": "off"
    }
  }
}
